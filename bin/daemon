#!/usr/bin/env python3

import json
import logging
import os
import socket

from pydantic import ValidationError

from epa_orchestrator.cpu_pinning import calculate_cpu_pinning, get_isolated_cpus
from epa_orchestrator.schemas import EpaRequest, EpaResponse, ErrorResponse

SOCKET_PATH = os.path.join(os.environ["SNAP_DATA"], "data", "epa.sock")

logging.basicConfig(level=logging.INFO)


def main():
    os.makedirs(os.path.dirname(SOCKET_PATH), exist_ok=True)

    if os.path.exists(SOCKET_PATH):
        os.remove(SOCKET_PATH)

    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as server:
        server.bind(SOCKET_PATH)
        os.chmod(SOCKET_PATH, 0o666)
        server.listen(1)
        logging.info(f"EPA orchestrator daemon listening on {SOCKET_PATH}")
        while True:
            conn, _ = server.accept()
            with conn:
                data = conn.recv(1024)
                if not data:
                    continue

                try:
                    request_data = json.loads(data.decode())
                    request = EpaRequest(**request_data)

                    isolated = get_isolated_cpus()
                    shared, dedicated = calculate_cpu_pinning(isolated, request.cores_requested)

                    response = EpaResponse(shared_cpus=shared, vcpu_pin_set=dedicated)
                    conn.sendall(response.json().encode())

                except (ValidationError, json.JSONDecodeError) as e:
                    error_response = EpaResponse(shared_cpus="", vcpu_pin_set="", error=str(e))
                    conn.sendall(error_response.json().encode())


if __name__ == "__main__":
    main()